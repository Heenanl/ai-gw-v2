# Test Configuration
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# These variables are used by all test scripts under tests/

# ============================================================================
# APIM Gateway Configuration (used by most tests)
# ============================================================================
APIM_ENDPOINT=https://<your-apim-name>.azure-api.net
APIM_AUDIENCE=api://<your-app-registration-client-id>
API_VERSION=2024-12-01-preview

# ============================================================================
# Model / Deployment Names
# ============================================================================
DEPLOYMENT_NAME=gpt-5-mini
MODEL_NAME=gpt-5-mini
EMBEDDINGS_DEPLOYMENT_NAME=text-embedding-3-small

# ============================================================================
# Foundry Configuration (used by test_foundry_agent.py, test_foundry_connection.py)
# ============================================================================
FOUNDRY_ACCOUNT=<your-ai-foundry-account-name>
FOUNDRY_PROJECT=<your-ai-foundry-project-name>
FOUNDRY_CONNECTION_NAME=<connection-name>
